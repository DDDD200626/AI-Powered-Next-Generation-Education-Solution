# 복사 후 .env 로 저장. .env 는 Git 에 커밋하지 마세요.

# 필수: 답변·요약·이해도·무결성 LLM (백엔드에서만 읽음)
OPENAI_API_KEY=sk-your-key-here

# 선택: 서버 키가 없을 때 프론트가 헤더 X-ClassPulse-OpenAI-Key 로 키 전송 허용 (1=허용). 공개 배포는 0 권장.
# CLASSPULSE_ALLOW_CLIENT_OPENAI_KEY=1

# 선택: 프론트가 다른 도메인일 때 CORS (콤마 구분, 공백 없이)
# CORS_ORIGINS=https://myapp.vercel.app,http://localhost:5173

# 선택: 빌드된 프론트를 FastAPI 한 프로세스에서 같이 쓸 때 (저장소 루트 기준 상대경로 가능)
# FRONTEND_DIST=frontend/dist
