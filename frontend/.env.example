# 비우기(권장): nginx/docker 가 /api 를 API 로 넘기거나, Vite dev 가 프록시.
# 직접 백엔드 호스트를 쓸 때만 설정 (끝에 / 없음). 예: VITE_API_BASE=http://127.0.0.1:8000
# 프로덕션 빌드 기본은 .env.production (상대 /api 유지)
VITE_API_BASE=
# Vite dev 프록시 대상(기본 8000). 이 파일을 frontend/.env.development.local 로 복사해 포트만 바꿔도 됨.
# VITE_DEV_BACKEND_URL=http://127.0.0.1:8010
