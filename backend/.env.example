# --- 다중 LLM (하나 이상 설정 권장; 없으면 규칙 기반 휴리스틱만) ---
# Google Gemini
GOOGLE_API_KEY=
# GEMINI_API_KEY=
# 팀 평가·비교 기본: gemini-2.5-flash (미지원 리전이면 gemini-2.0-flash 등으로 변경)
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI (ChatGPT API)
OPENAI_API_KEY=
# 팀 평가·비교 기본: gpt-4o
# OPENAI_MODEL=gpt-4o
# 팀 평가·JSON 평가 호출 타임아웃(초, 기본 120)
# OPENAI_TIMEOUT_SEC=120

# POST /api/team/report 설명용 LLM: auto(제미나이 우선, 없으면 OpenAI) | gemini | openai | multi(둘 다 병렬·합성)
# TEAM_REPORT_LLM=auto
# TEAM_REPORT_OPENAI_MODEL=gpt-4o
# TEAM_REPORT_GEMINI_MODEL=gemini-2.5-flash

# DL 점수에 선택적 LLM 정렬 레이어(팀당 1회 JSON). 1이면 GOOGLE_API_KEY 또는 GEMINI_API_KEY 또는 OPENAI_API_KEY 필요
# TEAM_DL_LLM_ASSIST=0
# dl_score에 혼합할 LLM alignment 비중(0~0.45, 기본 0.18)
# TEAM_DL_LLM_BLEND=0.18
# TEAM_DL_LLM_GEMINI_MODEL=gemini-2.0-flash
# TEAM_DL_LLM_OPENAI_MODEL=gpt-4o-mini

# 자기서술 문장 임베딩(TEAM_SEMANTIC_ENCODER=1) — 학습 시 끝 8차원에만 과적합 완화(추론 피처는 그대로)
# TEAM_SEMANTIC_AUTO_REG=1
# TEAM_SEMANTIC_AUTO_REG=0
# TEAM_SEMANTIC_ANTI_OVERFIT=0
# TEAM_SEMANTIC_ANTI_OVERFIT=1
# TEAM_SEMANTIC_TRAIN_DROPOUT=
# TEAM_SEMANTIC_TRAIN_SCALE=

# Anthropic Claude
ANTHROPIC_API_KEY=
# 팀 평가·비교 기본: Claude Sonnet 4
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# xAI Grok (OpenAI 호환 엔드포인트)
XAI_API_KEY=
# GROK_API_KEY=
# 팀 평가·비교 기본: grok-3-latest
# GROK_MODEL=grok-3-latest
# XAI_BASE_URL=https://api.x.ai/v1

# CORS (Vite 5173·preview 4173·Docker 웹 8080 등 기본 포함, 필요 시 덮어쓰기)
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# LAN에서 http://192.168.x.x:5173 으로 접속 시 직접 API 호출 허용(기본 정규식). 끄려면: CORS_ORIGIN_REGEX=0
# CORS_ORIGIN_REGEX=0

# 운영·관측성 (GET /api/observability JSON에 노출)
# APP_ENV=production
# GIT_COMMIT=abc123def456
# SOURCE_COMMIT= (일부 CI)

# 최근 요청 처리 시간 링 버퍼 (GET /api/perf/recent). 끄려면: 0
# PERF_RING_BUFFER=1

# 공개 벤치마크 priors(선택): 크롤링 없이 승인된 JSON 1곳(URL) 또는 레포 내 로컬 파일
# TEAM_WEB_PRIORS_ENABLED=0
# TEAM_WEB_PRIORS_URL=https://example.com/team-priors.json
# TEAM_WEB_PRIORS_FILE=edu_tools/data/team-priors.sample.json
# 전역 강도(0~2, 기본 1): 외부 기대값 보정을 줄이거나 키움 — dl_model_info.prior_calibration 에 기록됨
# TEAM_WEB_PRIORS_STRENGTH=1
# 외부 JSON 기대값만으로 정렬 점수(0–100)를 만들어 NN dl_score와 혼합 (추가 학습 불필요). JSON benchmark_inference.enabled 또는:
# TEAM_BENCHMARK_INFERENCE_ENABLED=0
# TEAM_BENCHMARK_INFERENCE_ENABLED=1
# TEAM_BENCHMARK_BLEND_WEIGHT=0.35
# 예시 포맷: backend/edu_tools/data/team-priors.sample.json

# 논문·연구 부록 JSON: 피처 앞 5개와 동일 스케일의 mean/std → z-정합 점수를 dl_score에 소폭 혼합 (크롤링 없음, 로컬 파일만)
# TEAM_RESEARCH_DATA_FILE=edu_tools/data/team-research-profile.sample.json
# JSON integration.enabled 또는 아래로 강제 켜기/끄기
# TEAM_RESEARCH_BLEND_ENABLED=0
# TEAM_RESEARCH_BLEND_ENABLED=1
# TEAM_RESEARCH_BLEND_WEIGHT=0.10

# 팀 DL 보조 모델 크기 (기본 standard). large=4층, xlarge_lite/xlarge/xxl=5층
# CPU 부담 적은 초대형: xlarge_lite (앙상블·MC·폭 축소, 구조는 5층)
# TEAM_TORCH_MODEL_SIZE=standard
# TEAM_TORCH_MODEL_SIZE=large
# TEAM_TORCH_MODEL_SIZE=xlarge_lite
# TEAM_TORCH_MODEL_SIZE=xlarge
# TEAM_TORCH_MODEL_SIZE=xxl
# 심사·최종 제출용 최고 품질( xxl 고정·앙상블/MC·그리드 상향, 학습 시간·메모리 크게 증가 )
# TEAM_TORCH_CONTEST_MAX=0
# TEAM_TORCH_CONTEST_MAX=1
# TEAM_TORCH_ENSEMBLE=8
# TEAM_TORCH_CV_FOLDS=5
# TEAM_TORCH_MC_SAMPLES=20

# 대용량 team_ml_dataset.jsonl 학습 시 메모리 상한(0이면 전체 로드). 합성 대량 추가 후 권장.
# TEAM_TRAIN_RESERVOIR_MAX=131072
# TEAM_TRAIN_RESERVOIR_SEED=42

# PyTorch CV: 동일 sess가 train/val에 섞이지 않게 분할(1). 끄면 인덱스 셔플만 사용.
# TEAM_TORCH_SESSION_CV=1

# 재학습 간격 무시하고 즉시 학습(실험·배포용). 1/true/on
# TEAM_RETRAIN_FORCE=0

# JSONL 추가 시 동일 지문(멤버·세션·x·y) 중복 행 생략. team_ml_fp_ring.json 유지
# TEAM_APPEND_DEDUP=0

# 라벨 y 이상치 제거(IQR k배, 0이면 끔). 데이터 늘린 뒤 권장
# TEAM_TRAIN_OUTLIER_IQR_K=0

# 시간 홀드아웃: created_at 기준 최근 비율을 학습에서 제외 후 holdout MAE·상관 기록 (0이면 끔)
# TEAM_HOLDOUT_TIME_FRAC=0

# 하이퍼파라미터 그리드에 변형 후보 추가(학습 시간 증가)
# TEAM_TORCH_EXTENDED_HP=0
