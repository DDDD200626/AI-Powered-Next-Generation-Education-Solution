# --- 다중 LLM (하나 이상 설정 권장; 없으면 규칙 기반 휴리스틱만) ---
# Google Gemini
GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI (ChatGPT API)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# 팀 평가·JSON 평가 호출 타임아웃(초, 기본 120)
# OPENAI_TIMEOUT_SEC=120

# Anthropic Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# xAI Grok (OpenAI 호환 엔드포인트)
XAI_API_KEY=
# GROK_API_KEY=
# GROK_MODEL=grok-2-latest
# XAI_BASE_URL=https://api.x.ai/v1

# CORS (Vite 5173·preview 4173·Docker 웹 8080 등 기본 포함, 필요 시 덮어쓰기)
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 운영·관측성 (GET /api/observability JSON에 노출)
# APP_ENV=production
# GIT_COMMIT=abc123def456
# SOURCE_COMMIT= (일부 CI)

# 최근 요청 처리 시간 링 버퍼 (GET /api/perf/recent). 끄려면: 0
# PERF_RING_BUFFER=1
